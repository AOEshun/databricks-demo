{
  "displayName": "tasty_bytes_sales",
  "datasets": [
    {
      "name": "monthly_revenue_by_currency",
      "displayName": "Monthly Revenue by Currency",
      "query": "SELECT d.year_month_start AS year_month, c.order_currency, SUM(f.order_total) AS total_revenue FROM DEMO.DATAMART.FCT_ORDER f JOIN DEMO.DATAMART.DIM_DATE d ON d.MK_DATE = f.MK_DATE JOIN DEMO.DATAMART.DIM_CURRENCY c ON c.MK_CURRENCY = f.MK_CURRENCY GROUP BY d.year_month_start, c.order_currency ORDER BY year_month"
    },
    {
      "name": "top_trucks_by_revenue",
      "displayName": "Top Trucks by Revenue",
      "query": "SELECT t.truck_id, SUM(f.order_total) AS total_revenue FROM DEMO.DATAMART.FCT_ORDER f JOIN DEMO.DATAMART.DIM_TRUCK t ON t.MK_TRUCK = f.MK_TRUCK GROUP BY t.truck_id ORDER BY total_revenue DESC LIMIT 10"
    },
    {
      "name": "top_locations_by_revenue",
      "displayName": "Top Locations by Revenue",
      "query": "SELECT l.location_id, SUM(f.order_total) AS total_revenue FROM DEMO.DATAMART.FCT_ORDER f JOIN DEMO.DATAMART.DIM_LOCATION l ON l.MK_LOCATION = f.MK_LOCATION GROUP BY l.location_id ORDER BY total_revenue DESC LIMIT 10"
    },
    {
      "name": "kpi_totals",
      "displayName": "KPI Totals",
      "query": "SELECT SUM(order_total) AS total_revenue, COUNT(*) AS total_orders FROM DEMO.DATAMART.FCT_ORDER"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview",
      "layout": [
        {
          "widget": {
            "name": "kpi_total_revenue",
            "title": "Total Revenue",
            "description": "Sum of all revenue across all trucks and dates",
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "kpi_totals",
                  "fields": [
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ]
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_total_orders",
            "title": "Total Orders",
            "description": "Sum of all orders across all trucks and dates",
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_orders",
                  "displayName": "Total Orders"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "kpi_totals",
                  "fields": [
                    {
                      "name": "total_orders",
                      "expression": "`total_orders`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ]
          },
          "position": {
            "x": 3,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "revenue_trend",
            "title": "Revenue Trend by Currency",
            "description": "Monthly revenue trend broken out by order currency",
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "year_month",
                  "displayName": "Month",
                  "scale": {
                    "type": "temporal"
                  }
                },
                "y": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "color": {
                  "fieldName": "order_currency",
                  "displayName": "Currency"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "monthly_revenue_by_currency",
                  "fields": [
                    {
                      "name": "year_month",
                      "expression": "`year_month`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    },
                    {
                      "name": "order_currency",
                      "expression": "`order_currency`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ]
          },
          "position": {
            "x": 0,
            "y": 3,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "top_trucks",
            "title": "Top 10 Trucks by Revenue",
