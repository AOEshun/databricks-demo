{
  "displayName": "tasty_bytes_sales",
  "datasets": [
    {
      "name": "monthly_revenue_by_currency",
      "displayName": "Monthly Revenue by Currency",
      "query": "SELECT year_month, order_currency, total_revenue FROM DEMO.DATAMART.monthly_revenue_by_currency ORDER BY year_month"
    },
    {
      "name": "top_trucks_by_revenue",
      "displayName": "Top Trucks by Revenue",
      "query": "SELECT truck_id, SUM(total_revenue) AS total_revenue FROM DEMO.DATAMART.daily_sales_by_truck GROUP BY truck_id ORDER BY total_revenue DESC LIMIT 10"
    },
    {
      "name": "top_locations_by_revenue",
      "displayName": "Top Locations by Revenue",
      "query": "SELECT location_id, SUM(total_revenue) AS total_revenue FROM DEMO.DATAMART.daily_sales_by_location GROUP BY location_id ORDER BY total_revenue DESC LIMIT 10"
    },
    {
      "name": "kpi_totals",
      "displayName": "KPI Totals",
      "query": "SELECT SUM(total_revenue) AS total_revenue, SUM(total_orders) AS total_orders FROM DEMO.DATAMART.daily_sales_by_truck"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview",
      "layout": [
        {
          "widget": {
            "name": "kpi_total_revenue",
            "title": "Total Revenue",
            "description": "Sum of all revenue across all trucks and dates",
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "kpi_totals",
                  "fields": [
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ]
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_total_orders",
            "title": "Total Orders",
            "description": "Sum of all orders across all trucks and dates",
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_orders",
                  "displayName": "Total Orders"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "kpi_totals",
                  "fields": [
                    {
                      "name": "total_orders",
                      "expression": "`total_orders`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ]
          },
          "position": {
            "x": 3,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "revenue_trend",
            "title": "Revenue Trend by Currency",
            "description": "Monthly revenue trend broken out by order currency",
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "year_month",
                  "displayName": "Month",
                  "scale": {
                    "type": "temporal"
                  }
                },
                "y": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "color": {
                  "fieldName": "order_currency",
                  "displayName": "Currency"
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "monthly_revenue_by_currency",
                  "fields": [
                    {
                      "name": "year_month",
                      "expression": "`year_month`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    },
                    {
                      "name": "order_currency",
                      "expression": "`order_currency`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ]
          },
          "position": {
            "x": 0,
            "y": 3,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "top_trucks",
            "title": "Top 10 Trucks by Revenue",
            "description": "Bar chart of top 10 trucks ranked by total revenue",
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "truck_id",
                  "displayName": "Truck ID",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "top_trucks_by_revenue",
                  "fields": [
                    {
                      "name": "truck_id",
                      "expression": "`truck_id`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ]
          },
          "position": {
            "x": 0,
            "y": 9,
            "width": 3,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "top_locations",
            "title": "Top 10 Locations by Revenue",
            "description": "Bar chart of top 10 locations ranked by total revenue",
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "location_id",
                  "displayName": "Location ID",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            },
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "top_locations_by_revenue",
                  "fields": [
                    {
                      "name": "location_id",
                      "expression": "`location_id`"
                    },
                    {
                      "name": "total_revenue",
                      "expression": "`total_revenue`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ]
          },
          "position": {
            "x": 3,
            "y": 9,
            "width": 3,
            "height": 6
          }
        }
      ]
    }
  ]
}
